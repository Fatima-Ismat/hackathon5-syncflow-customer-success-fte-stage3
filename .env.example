# ============================================================
# SyncFlow Customer Success Digital FTE — Environment Variables
# ============================================================
# For local development:
#   cp .env.example .env
#   Edit .env with your values, then:
#   uvicorn api.main:app --reload --port 8000
#
# For Hugging Face Spaces:
#   Add these as Repository Secrets in your Space settings.
#   Do NOT copy this file into your Space — use the Secrets UI.
#
# All variables are optional unless marked REQUIRED.
# The system runs in full mock/demo mode with zero credentials.
# ============================================================


# ── Port ─────────────────────────────────────────────────────
# Hugging Face Spaces REQUIRES port 7860.
# Local development: use 8000.
PORT=7860


# ── OpenAI ───────────────────────────────────────────────────
# Optional. The rule-based fallback agent is always active.
# If not set: responses use keyword matching + templates.
# If set: OpenAI Agents SDK is used for richer responses.
OPENAI_API_KEY=sk-...


# ── Database ─────────────────────────────────────────────────

# Option A — PostgreSQL (recommended for production / HF Spaces)
# Get a free connection string from https://neon.tech or https://supabase.com
DATABASE_URL=postgresql://user:password@host:5432/syncflow_crm?sslmode=require

# Option B — SQLite file (local dev default — no setup needed)
# DATABASE_URL=sqlite:///./syncflow_dev.db

# Option C — SQLite in-memory (testing only — data lost on restart)
# DATABASE_URL=sqlite://


# ── Kafka ────────────────────────────────────────────────────
# KAFKA_MOCK_MODE=true → in-memory mock broker (default, zero config)
# KAFKA_MOCK_MODE=false → real Kafka via KAFKA_BOOTSTRAP_SERVERS
KAFKA_MOCK_MODE=true

# For Confluent Cloud (only needed when KAFKA_MOCK_MODE=false):
# KAFKA_BOOTSTRAP_SERVERS=pkc-xxx.us-east-1.aws.confluent.cloud:9092
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=YOUR_CONFLUENT_API_KEY
# KAFKA_SASL_PASSWORD=YOUR_CONFLUENT_API_SECRET

# For local Kafka (docker-compose):
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_SECURITY_PROTOCOL=PLAINTEXT


# ── WhatsApp / Twilio ─────────────────────────────────────────
# Optional. Leave empty for mock mode.
# Mock mode: WhatsApp replies are returned in the API response body.
# Live mode: replies are actually sent via Twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# WhatsApp Business API (Meta) webhook verification token
WHATSAPP_VERIFY_TOKEN=syncflow_verify_2025


# ── Gmail ────────────────────────────────────────────────────
# Optional. Leave empty for mock mode.
# Mock mode: email replies are returned in the API response body.
# Live mode: provide OAuth credentials from Google Cloud Console.
# Download from: Google Cloud Console → APIs → Gmail API → Credentials → OAuth 2.0
GMAIL_CREDENTIALS_JSON=


# ── Frontend / CORS ──────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Vercel deployment URL here.
CORS_ORIGINS=http://localhost:3000,https://syncflow-support.vercel.app

# Your deployed API base URL — used for Twilio webhook signature validation.
# Set to your Hugging Face Space URL after deployment.
WEBHOOK_BASE_URL=https://YOUR-USERNAME-syncflow-api.hf.space


# ── Workers ──────────────────────────────────────────────────
# Number of uvicorn worker processes.
# Keep at 1 when using SQLite (single-writer).
# Increase to 2-4 when using PostgreSQL on a paid HF tier.
WORKERS=1


# ── Hugging Face Spaces — Secrets to set in the Space UI ─────
# Copy the values above into: Space → Settings → Repository secrets
#
#   Secret name          │ Value
#   ─────────────────────┼──────────────────────────────────────
#   PORT                 │ 7860
#   OPENAI_API_KEY       │ sk-...              (if using OpenAI)
#   DATABASE_URL         │ postgresql://...    (if using Neon)
#   KAFKA_MOCK_MODE      │ true
#   CORS_ORIGINS         │ https://YOUR-FRONTEND.vercel.app
#   WEBHOOK_BASE_URL     │ https://YOUR-SPACE.hf.space
#   WORKERS              │ 1
